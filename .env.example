# =============================================================================
# PathUp — Environment Variables
# Скопируй в .env.local и заполни реальными значениями
# =============================================================================

# DATABASE
# Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# OPENAI
# platform.openai.com → API keys
OPENAI_API_KEY="sk-..."

# YOOKASSA (оплата)
# yookassa.ru → Настройки → Интеграция
YOOKASSA_SHOP_ID="12345"
YOOKASSA_SECRET_KEY="test_..."

# RESEND (email)
# resend.com → API Keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="PathUp <hello@pathup.ru>"

# APP
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# В продакшне: https://pathup.ru

# ADMIN
# Придумай длинный случайный секрет
ADMIN_SECRET="change-me-to-a-long-random-string"

# CRON JOBS (Vercel Cron)
# Такой же подход — длинный случайный секрет
CRON_SECRET="change-me-to-another-long-random-string"

# =============================================================================
# MOCK MODE (для разработки без внешних сервисов)
# =============================================================================

# true = не вызываем OpenAI, возвращаем mock отчёты
MOCK_MODE="true"

# true = не вызываем ЮКасса, симулируем успешную оплату
PAYMENT_MOCK="true"

# =============================================================================
# PRICING
# =============================================================================

# Цена полного плана в рублях
NEXT_PUBLIC_PRICE_RUB="790"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# true = показывать parent report секцию
NEXT_PUBLIC_PARENT_REPORT_ENABLED="false"

# true = включить страницу /admin
ADMIN_ENABLED="true"
